generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  notifiedAt DateTime @default(now()) @db.Timestamp(6)
  fromUserId String   @db.Uuid
  isRead     Boolean  @default(false)
  postId     String?  @db.Uuid
  toUserId   String   @db.Uuid
  type       String
  user1      User     @relation("sendBy", fields: [fromUserId], references: [id])
  post       Post?    @relation(fields: [postId], references: [id])
  user2      User     @relation("receiveBy", fields: [toUserId], references: [id])
}

model FriendRequest {
  id          String    @id @default(uuid()) @db.Uuid
  senderId    String    @db.Uuid
  receiverId  String    @db.Uuid
  isAccepted  Boolean?
  requestedAt DateTime  @default(now()) @db.Timestamp(6)
  acceptedAt  DateTime? @updatedAt
  type        Request
  receiver    User      @relation("ReceiverRequests", fields: [receiverId], references: [id])
  sender      User      @relation("SenderRequests", fields: [senderId], references: [id])

  @@unique([senderId, receiverId])
}

model Friendship {
  id         String   @id @default(uuid()) @db.Uuid
  follower   String   @db.Uuid
  following  String   @db.Uuid
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  followers  User     @relation("Friendship_followerToUser", fields: [follower], references: [id], map: "Friendship_user1Id_fkey")
  followings User     @relation("Friendship_followingToUser", fields: [following], references: [id], map: "Friendship_user2Id_fkey")

  @@unique([follower, following], map: "Friendship_user1Id_user2Id_key")
}

model CommentLike {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  postId    String   @db.Uuid
  commentId String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamp(6)
  comment   Comment  @relation(fields: [commentId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, postId, commentId])
}

model PostLike {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  postId    String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamp(6)
  is_liked  Boolean? @default(true)
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
}

model Comment {
  id          String        @id @default(uuid()) @db.Uuid
  comment     String
  authorId    String?       @db.Uuid
  postId      String?       @db.Uuid
  createdAt   DateTime      @default(now()) @db.Timestamp(6)
  likeCount   Int           @default(0)
  author      User?         @relation(fields: [authorId], references: [id])
  Post        Post?         @relation(fields: [postId], references: [id])
  CommentLike CommentLike[]
}

model Post {
  id           String         @id @default(uuid()) @db.Uuid
  title        String         @unique
  content      String
  authorId     String         @db.Uuid
  createdAt    DateTime       @default(now()) @db.Timestamp(6)
  likeCount    Int            @default(0)
  category     Category       @default(UNDEFINED)
  is_revoked   Boolean?       @default(false)
  Comment      Comment[]
  CommentLike  CommentLike[]
  Notification Notification[]
  author       User           @relation(fields: [authorId], references: [id])
  postLikes    PostLike[]
}

model User {
  id                                    String          @id @default(uuid()) @db.Uuid
  name                                  String          @db.VarChar(100)
  email                                 String          @unique @db.VarChar(100)
  password                              String?         @db.VarChar(255)
  createdAt                             DateTime        @default(now()) @db.Timestamp(6)
  role                                  Role            @default(USER)
  status                                user_status?    @default(offline)
  is_activated                          Boolean?        @default(true)
  codeExpiry                            DateTime?       @db.Timestamp(6)
  verificationCode                      String?         @db.Char(6)
  auth_method                           String?         @default("email") @db.VarChar(50)
  auth_method_id                        String?         @unique @db.VarChar(255)
  profile_image                         String?
  bio                                   String?
  Comment                               Comment[]
  CommentLike                           CommentLike[]
  FriendRequestReceived                 FriendRequest[] @relation("ReceiverRequests")
  FriendRequestSent                     FriendRequest[] @relation("SenderRequests")
  Friendship_Friendship_followerToUser  Friendship[]    @relation("Friendship_followerToUser")
  Friendship_Friendship_followingToUser Friendship[]    @relation("Friendship_followingToUser")
  Message                               Message[]       @relation("UserMessages")
  Notification1                         Notification[]  @relation("sendBy")
  Notification2                         Notification[]  @relation("receiveBy")
  Participant                           Participant[]
  posts                                 Post[]
  postLikes                             PostLike[]
}

model ChatRoom {
  id           String        @id @default(uuid()) @db.Uuid
  name         String?
  isGroup      Boolean       @default(false)
  createdAt    DateTime      @default(now()) @db.Timestamp(6)
  messages     Message[]
  participants Participant[]
}

model Participant {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String            @db.Uuid
  chatRoomId String            @db.Uuid
  role       participant_role? @default(member)
  chatRoom   ChatRoom          @relation(fields: [chatRoomId], references: [id])
  user       User              @relation(fields: [userId], references: [id])

  @@unique([userId, chatRoomId])
}

model Message {
  id         String   @id @default(uuid()) @db.Uuid
  content    String
  seenAt     DateTime @default(now()) @db.Timestamp(6)
  senderId   String   @db.Uuid
  chatRoomId String   @db.Uuid
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id])
  sender     User     @relation("UserMessages", fields: [senderId], references: [id])

  // Cursor pagination on timestamps
  @@unique([seenAt, id])
}

enum Role {
  USER
  ADMIN
}

enum Request {
  FRIEND_REQUEST_ACCEPTED
  FRIEND_REQUEST_SENT
  FRIEND_REQUEST_REJECTED
  FRIEND_REQUEST_REVOKED
}

enum Category {
  UNDEFINED
  PROGRAMMING
  GAMES
  ANIME
  MOVIES
}

enum Msg {
  USER_REQUEST
  USER_REQUEST_ACCEPTED
  LIKE_POST
  CREATE_POST
  COMMENT_POST
}

enum user_status {
  online
  offline
}

enum participant_role {
  member
  creator
  admin
}
